DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id
# Optional: one fast-registration guild for development
DISCORD_GUILD_ID=your-dev-guild-id
# Optional: comma-separated fast-registration guilds for multi-server development
# Example: DISCORD_GUILD_IDS=123456789012345678,987654321098765432
DISCORD_GUILD_IDS=
DATABASE_URL=postgresql://postgres:postgres@db:5432/leetcord?schema=public
API_PORT=3000
BOT_PUBLIC_URL=http://localhost:3000
LEETCODE_FETCH_USER_AGENT=LeetCordBot/0.1.0
LOG_LEVEL=info
