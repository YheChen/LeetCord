{
  "name": "leetcord-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm build && pnpm -r --parallel --stream --filter @leetcord/api --filter @leetcord/bot --filter @leetcord/worker dev",
    "dev:bot": "pnpm --filter @leetcord/bot dev",
    "dev:api": "pnpm --filter @leetcord/api dev",
    "dev:worker": "pnpm --filter @leetcord/worker dev",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "prisma:generate": "pnpm --filter @leetcord/database prisma:generate",
    "prisma:migrate": "pnpm --filter @leetcord/database prisma:migrate:dev",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
